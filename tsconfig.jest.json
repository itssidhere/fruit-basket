{
    "extends": "./tsconfig.json",
    "compilerOptions": {
      "jsx": "react-jsx",
      "esModuleInterop": true,
      "module": "CommonJS",
      "types": ["jest", "@testing-library/jest-dom", "node"]
    },
    "include": [
      "src/**/*.ts",
      "src/**/*.tsx",
